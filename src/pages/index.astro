---
import BaseLayout from '../layouts/BaseLayout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import { siteContent } from '../lib/content';

const { landing } = siteContent;
---

<BaseLayout title={`${siteContent.meta.title} · ${siteContent.meta.description}`} description={siteContent.meta.description} current="landing">
  <section class="shell grid gap-12 py-14 md:py-18 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)] lg:items-start lg:gap-10 lg:py-24">
    <div class="space-y-8">
      <div class="space-y-5">
        <Eyebrow label={landing.eyebrow} />
        <h1 class="max-w-4xl text-balance text-4xl font-semibold leading-[0.95] tracking-[-0.04em] text-[color:var(--fg)] sm:text-5xl lg:text-[4.6rem]">
          <span class="block">{landing.headline[0]}</span>
          <span class="block text-[color:var(--accent-strong)]">{landing.headline[1]}</span>
        </h1>
        <p class="section-copy text-pretty">{landing.subcopy}</p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row">
        <a href="/start" class="button-primary focus-ring min-w-[15rem]">{landing.primaryCta}</a>
        <a href="#how-it-works" class="button-secondary focus-ring min-w-[15rem]">{landing.secondaryCta}</a>
      </div>

      <ul class="flex flex-wrap gap-2 text-[0.72rem] uppercase tracking-[0.22em] text-[color:var(--muted)]">
        {landing.chips.map((chip) => (
          <li class="surface-muted px-3 py-2 font-mono">{chip}</li>
        ))}
      </ul>
    </div>

    <div class="terminal-frame surface-elevated overflow-hidden p-1">
      <div class="surface-muted h-full p-5 sm:p-6">
        <div class="flex items-center justify-between gap-4 font-mono text-[0.68rem] uppercase tracking-[0.28em] text-[color:var(--muted)]">
          <span>baseline.scan</span>
          <span class="text-[color:var(--success)]">ready</span>
        </div>

        <div class="mt-6 grid gap-3 text-sm text-[color:var(--muted)]">
          {landing.console.map((line, index) => (
            <div class:list={[index === 0 ? 'status-line' : '', 'surface px-4 py-3 font-mono text-[0.85rem] leading-6 text-[color:var(--muted-strong)]']}>
              <span class="block truncate">{line}</span>
            </div>
          ))}
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-3">
          <div class="surface px-4 py-4">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.28em] text-[color:var(--muted)]">flow</p>
            <p class="mt-2 text-lg font-semibold text-[color:var(--fg)]">route-based</p>
          </div>
          <div class="surface px-4 py-4">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.28em] text-[color:var(--muted)]">questions</p>
            <p class="mt-2 text-lg font-semibold text-[color:var(--fg)]">03</p>
          </div>
          <div class="surface px-4 py-4">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.28em] text-[color:var(--muted)]">output</p>
            <p class="mt-2 text-lg font-semibold text-[color:var(--fg)]">1st mission</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="how-it-works" class="border-y border-white/6 bg-black/10 py-16 md:py-20">
    <div class="shell grid gap-10 lg:grid-cols-[minmax(0,1fr)_12rem] lg:items-end">
      <div class="space-y-4">
        <Eyebrow label={landing.howItWorksTitle} />
        <p class="section-copy">{landing.howItWorksBody}</p>
      </div>
      <p class="font-mono text-4xl uppercase tracking-[0.12em] text-[color:var(--surface-elevated)] lg:text-right">01-04</p>
    </div>

    <div class="shell mt-8 grid gap-px bg-white/6 md:grid-cols-2 xl:grid-cols-4">
      {landing.howItWorksSteps.map((step) => (
        <article class="surface px-5 py-6">
          <p class="font-mono text-[0.68rem] uppercase tracking-[0.28em] text-[color:var(--accent-strong)]">{step.index}</p>
          <h2 class="mt-4 text-xl font-semibold tracking-[-0.02em] text-[color:var(--fg)]">{step.title}</h2>
          <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{step.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="missions" class="shell py-16 md:py-20">
    <div class="mx-auto max-w-3xl text-center">
      <Eyebrow label={landing.missionsTitle} />
      <p class="mt-4 text-balance text-3xl font-semibold tracking-[-0.03em] text-[color:var(--fg)] md:text-4xl">
        {landing.missionsTitle}
      </p>
      <p class="mx-auto mt-4 max-w-2xl text-sm leading-7 text-[color:var(--muted)]">{landing.missionsBody}</p>
    </div>

    <div class="mt-10 grid gap-px bg-white/6 md:grid-cols-2 xl:grid-cols-3">
      {landing.missionCards.map((card) => (
        <article class="surface px-5 py-6">
          <div class="flex items-start justify-between gap-4">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.28em] text-[color:var(--muted)]">{card.code}</p>
            <span class="font-mono text-[0.75rem] uppercase tracking-[0.24em] text-[color:var(--success)]">ready</span>
          </div>
          <h2 class="mt-4 text-xl font-semibold tracking-[-0.02em] text-[color:var(--fg)]">{card.title}</h2>
          <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="border-y border-white/6 bg-black/15 py-16 md:py-20">
    <div class="shell grid gap-px bg-white/6 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)]">
      <article class="surface px-6 py-7 sm:px-8">
        <Eyebrow label={landing.sprintTitle} />
        <h2 class="mt-4 max-w-2xl text-3xl font-semibold tracking-[-0.03em] text-[color:var(--fg)]">A short sprint for operators who need the next fix, not another scorecard.</h2>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-[color:var(--muted)]">{landing.sprintBody}</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="/start" class="button-primary focus-ring min-w-[15rem]">Run the baseline</a>
          <a href="/#how-it-works" class="button-secondary focus-ring min-w-[15rem]">See how it works</a>
        </div>
      </article>

      <aside class="surface-muted px-6 py-7 sm:px-8">
        <p class="font-mono text-[0.7rem] uppercase tracking-[0.28em] text-[color:var(--muted)]">Mission preview</p>
        <div class="mt-5 space-y-4">
          {landing.sprintStats.map((stat) => (
            <div class="flex items-center justify-between border-b border-white/6 pb-3 font-mono text-[0.78rem] uppercase tracking-[0.24em] text-[color:var(--muted)] last:border-none last:pb-0">
              <span>{stat.label}</span>
              <span class="text-[color:var(--fg)]">{stat.value}</span>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="shell py-16 md:py-20">
    <div class="surface-elevated terminal-grid overflow-hidden px-6 py-12 text-center sm:px-8">
      <div class="mx-auto max-w-2xl space-y-4">
        <div class="surface mx-auto max-w-fit px-4 py-3 font-mono text-[0.78rem] leading-6 text-[color:var(--muted-strong)] status-line">
          <span class="block">ready to calibrate mission pacing</span>
          <span class="block">queue operator report</span>
          <span class="block">route first mission</span>
        </div>
        <h2 class="text-balance text-3xl font-semibold tracking-[-0.03em] text-[color:var(--fg)] md:text-4xl">{landing.closingTitle}</h2>
        <div class="flex flex-col justify-center gap-3 sm:flex-row">
          <a href="/start" class="button-primary focus-ring min-w-[15rem]">Run the baseline</a>
          <a href="/#how-it-works" class="button-secondary focus-ring min-w-[15rem]">See how it works</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
